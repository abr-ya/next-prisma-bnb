{
  "name": "next-prisma-bnb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint \"./app/**/*.{js,ts,tsx}\" --quiet",
    "lint:staged": "lint-staged",
    "fix": "eslint \"./app/**/*.{js,ts,tsx}\" --fix",
    "fix-cmp": "eslint \"./components/**/*.{js,ts,tsx}\" --fix",
    "postinstall": "prisma generate",
    "tsc": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:resolve:baseline": "prisma migrate resolve --applied 20260511150000_prod_baseline",
    "db:migrate:resolve:pin-unique": "prisma migrate resolve --applied 20260511153000_pin_trip_title_unique",
    "prepare": "husky"
  },
  "dependencies": {
