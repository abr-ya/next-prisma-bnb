    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.9.4",
    "next": "15.2.8",
    "react": "^19.2.0",
    "react-color": "^2.19.3",
    "react-date-range": "^2.0.1",
    "react-dom": "^19.2.0",
